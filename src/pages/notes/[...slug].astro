---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const posts = (await getCollection("notes")).filter((post) => !post.data.draft);
  const getSlug = (post) => {
    if (post.slug) return post.slug;
    const filename = post.id.split("/").pop() ?? post.id;
    return filename.replace(/\.mdx?$/, "");
  };
  return posts.map((post) => ({
    params: { slug: getSlug(post) },
  }));
}

const posts = await getCollection("notes");
const post = posts.find((entry) => {
  const filename = entry.id.split("/").pop() ?? entry.id;
  const slug = entry.slug ?? filename.replace(/\.mdx?$/, "");
  return slug === Astro.params.slug;
});
if (!post) {
  return new Response(null, { status: 404 });
}
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} | Kodai Utsunomiya`} description={post.data.description ?? ""}>
  <Header baseHref="/" />

  <main class="l-container notes-page">
    <section class="l-section">
      <div class="c-card notes-card">
        <div class="notes-card__meta">
          <h1 class="notes-card__title">{post.data.title}</h1>
          <p class="timeline__date">{post.data.pubDate.toLocaleDateString("en-CA")}</p>
        </div>
        <div class="notes-content">
          <Content />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
