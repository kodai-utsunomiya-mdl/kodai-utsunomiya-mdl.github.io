---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("notes"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getSlug = (post) => {
  if (post.slug) return post.slug;
  const filename = post.id.split("/").pop() ?? post.id;
  return filename.replace(/\.mdx?$/, "");
};

const postsData = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description ?? "",
  pubDate: post.data.pubDate.toLocaleDateString("en-CA"),
  slug: getSlug(post),
  body: post.body ?? "",
}));
---
<BaseLayout title="Notes | Kodai Utsunomiya" description="Notes by Kodai Utsunomiya">
  <Header baseHref="/" />

  <main class="l-container notes-page">
    <section class="l-section">
      <h2 class="l-section__title">Notes</h2>
      <form class="notes-search notes-search--sticky" id="notes-search-form">
        <input
          id="notes-search-input"
          class="admin__input notes-search__input"
          type="search"
          placeholder="Search notes"
          aria-label="Search notes"
        />
        <button class="notes-search__button" type="submit">Search</button>
        <button
          class="notes-search__clear is-hidden"
          type="button"
          id="notes-search-clear"
        >
          Clear
        </button>
        <p class="notes-search__count" id="notes-search-count">
          All {posts.length} notes
        </p>
      </form>
      <div id="notes-list">
        {posts.map((post) => (
          <div class="c-card">
            <h3 class="c-card__title">
              <a href={`/notes/${getSlug(post)}/`}>{post.data.title}</a>
            </h3>
            {post.data.description && (
              <p class="c-text">{post.data.description}</p>
            )}
            <p class="timeline__date">{post.data.pubDate.toLocaleDateString("en-CA")}</p>
          </div>
        ))}
      </div>
      <script
        type="application/json"
        id="notes-data"
        set:html={JSON.stringify(postsData)}
      ></script>
    </section>
  </main>

  <Footer />

  <script src="/js/notes.js" defer></script>
</BaseLayout>
